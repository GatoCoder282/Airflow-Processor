APP_NAME=airflow-etl-processor
APP_ENV=dev
APP_LOG_LEVEL=INFO

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_BLOCK_MS=4000
REDIS_BATCH_COUNT=100

STREAM_AIRFLOW_EVENTS=stream:airflow_events
STREAM_ALERTS=stream:alerts
STREAM_CATALOG_SYNC=stream:dag_catalog_sync

GROUP_BACKEND_PROCESSORS=backend_processors
GROUP_CATALOG_SYNC=catalog_sync_processors
