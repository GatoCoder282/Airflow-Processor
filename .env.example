APP_NAME=airflow-etl-processor
APP_ENV=dev
APP_LOG_LEVEL=INFO

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_BLOCK_MS=4000
REDIS_BATCH_COUNT=100

STREAM_AIRFLOW_EVENTS=stream:airflow_events
STREAM_ALERTS=stream:alerts
STREAM_CATALOG_SYNC=stream:dag_catalog_sync

GROUP_BACKEND_PROCESSORS=backend_processors
GROUP_CATALOG_SYNC=catalog_sync_processors
CONSUMER_NAME=processor-1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datax
POSTGRES_USER=datax_backend
POSTGRES_PASSWORD=change_me

REFRESH_CURRENT_STATUS_SECONDS=15
REFRESH_PERFORMANCE_SECONDS=300
REFRESH_BROKEN_URL_SECONDS=600

ALERT_GRACE_SECONDS=120
DURATION_DEVIATION_WARNING_PERCENT=150

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Taiga (replaces Slack) — creates issues for critical alerts
# Get token from Taiga > Settings > Apps > User token
TAIGA_URL=https://taiga.mycompany.com
TAIGA_AUTH_TOKEN=your_taiga_token_here
TAIGA_PROJECT_ID=123